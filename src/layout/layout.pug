block vars 
  - var title = 'Collection Tracker'
  - var script = 'index.ts'
  - var assetBase = assetBase || '../'

block styles 
  - var stylesheets = ['styles.css']

include mixins.pug

// call head mixin with safe defaults if child pages override `block vars`
+head((typeof title === 'undefined') ? 'Collection Tracker' : title, (typeof script === 'undefined') ? 'index.ts' : script, (typeof stylesheets === 'undefined') ? ['styles.css'] : stylesheets)
body
  header
    h1.page-title= title
    coin-counter
  main
    block content
    block text 
      section.text 
        | Welcome to Collection Tracker, the ultimate tool for managing your FIFA World Cup 2026 sticker collection! Keep track of your stickers, see which ones you have, and find out which ones you're missing. Whether you're a seasoned collector or just starting out, Collection Tracker helps you stay organized and make the most of your sticker collection.